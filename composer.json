{
  "name": "lenonleite/bouncer-bundle",
  "description": "Bouncer email verification integration for Mautic",
  "type": "mautic-plugin",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Lenon Leite",
      "email": "lenonleite@gmail.com"
    }
  ],
  "keywords": [
    "mautic",
    "plugin",
    "bouncer",
    "email verification"
  ],
  "extra": {
    "install-directory-name": "LenonLeiteBouncerBundle"
  },
  "require": {
    "mautic/core-lib": "^5.0"
  },
  "require-dev": {
    "liip/functional-test-bundle": "^4.2",
    "liip/test-fixtures-bundle": "^1.6",
    "phpunit/phpunit": "^9.5",
    "symfony/browser-kit": "^5.4",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "MauticPlugin\\LenonLeiteBouncerBundle\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MauticPlugin\\LenonLeiteBouncerBundle\\Tests\\": "Tests"
    }
  },
  "minimum-stability": "dev",
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "php-http/discovery": false
    }
  }
}
